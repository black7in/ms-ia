# App
PORT=8002
ENVIRONMENT=production
FLASK_DEBUG=false

# JWT (mismo secret que MS-Core)
JWT_SECRET=

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_EVIDENCIAS=bustrack-evidencias
S3_BUCKET_LICENCIAS=bustrack-licencias

# DynamoDB (vacio = AWS real)
DYNAMODB_ENDPOINT=
DYNAMODB_TABLE_INFERENCIAS=inferencias_ia
DYNAMODB_TABLE_PREDICCIONES=predicciones_ml

# MS-Core
MS_CORE_URL=http://localhost:3000

# Mocks (false = real)
MOCK_REKOGNITION=false
MOCK_S3=false
MOCK_PUSH_NOTIFICATIONS=false

# Notificaciones
EXPO_ACCESS_TOKEN=

# OpenAI (agente IA)
OPENAI_API_KEY=

# Umbrales
UMBRAL_IDENTIDAD_FACIAL=90.0
UMBRAL_SOMNOLENCIA=70.0

# CORS
CORS_ORIGINS=http://localhost:4200
